# Agent Grey - Core Requirements Environment Configuration
# Copy this file to .env.local and add your actual values

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Docker Volume Mount Path (for docker-outside-of-docker setups)
# If using VS Code devcontainer with docker-outside-of-docker feature,
# set this to your Windows host path, e.g.:
#   PROJECT_PATH=/d/path/to/agent-grey-core-requirements
# If running Docker directly on host, leave empty or comment out:
#   PROJECT_PATH=
# The default is "." (current directory)

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-this-in-production
DJANGO_SETTINGS_MODULE=grey_lit_project.settings.local

# Database Configuration (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@db:5432/thesis_grey_dev_db
DB_NAME=thesis_grey_dev_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# =============================================================================
# SEARCH API CONFIGURATION (REQUIRED)
# =============================================================================

# Serper API (Required for search functionality)
# Get your API key from: https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# Perplexity API (Optional - for Claude Code MCP integration)
# Get your API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# =============================================================================
# BACKGROUND PROCESSING
# =============================================================================

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Queue Configuration
USE_DRAMATIQ_FOR_SEARCH=False

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# Email Configuration (Optional - for notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# =============================================================================
# LOGGING & NOISE CONTROL
# =============================================================================
# For quiet development (reduced noise), see .env.quiet or use:
#   OTEL_ENABLED=false APP_LOG_LEVEL=WARNING docker-compose up
#
# For full debugging:
#   OTEL_ENABLED=true DEV_REQUEST_LOGGING=all DB_LOG_LEVEL=DEBUG docker-compose up

# Application log level (DEBUG, INFO, WARNING, ERROR)
# Defaults to WARNING for quiet development
LOG_LEVEL=WARNING
DJANGO_LOG_LEVEL=WARNING
APP_LOG_LEVEL=WARNING

# Request logging mode: all | errors_only (default) | errors_and_slow
DEV_REQUEST_LOGGING=errors_only

# Database query logging
LOG_SQL_QUERIES=False
DB_LOG_LEVEL=WARNING

# Security (Development only)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Enable Django Debug Toolbar
USE_DEBUG_TOOLBAR=True

# Performance monitoring (Optional)
ENABLE_QUERY_LOGGING=False
ENABLE_PERFORMANCE_LOGGING=False

# =============================================================================
# OPENTELEMETRY DISTRIBUTED TRACING (Phase 2)
# =============================================================================

# Enable/disable OpenTelemetry tracing (disabled by default for quiet dev)
# For verbose tracing: OTEL_ENABLED=true docker-compose up
OTEL_ENABLED=False

# Service identification
OTEL_SERVICE_NAME=agent-grey
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENV=development

# Jaeger Exporter (Development)
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# OTLP Exporter (Production - leave empty for dev)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Django-specific settings
OTEL_DJANGO_SQL_COMMENTER=False

# =============================================================================
# GRAFANA CONFIGURATION (Phase 4)
# =============================================================================

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=secure_password_here

# =============================================================================
# DEV COMPOSE CREDENTIALS (docker-compose.development.yml)
# =============================================================================
# Dev-only credentials required by docker-compose.development.yml
# (Flower Celery monitoring UI + pgAdmin). Copy this file to
# .env.dev.local and set strong unique values. The compose file uses
# ${VAR:?set in .env.dev.local} so missing values will block startup.
FLOWER_ADMIN_PASSWORD=change-me-to-a-strong-random-value
PGADMIN_PASSWORD=change-me-to-a-strong-random-value

# Dev compose requires these (docker-compose.{development,minimal}.yml use
# ${POSTGRES_PASSWORD:?}). Copy to .env.dev.local and set a strong value.
POSTGRES_PASSWORD=change-me-to-a-strong-random-value

# Staging compose requires these (docker-compose.staging.yml). Copy to
# .env.staging.local.
# (Reuses the POSTGRES_PASSWORD above.)
REDIS_PASSWORD=change-me-to-a-strong-random-value

# Comma-separated Chrome/Edge extension ids allowed to call /api/extension/*.
# Leave blank in local dev (any id is accepted while DEBUG=True).
ALLOWED_EXTENSION_IDS=
