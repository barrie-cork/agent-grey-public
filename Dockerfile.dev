# Multi-stage Dockerfile optimized for development
# Stage 1: Base dependencies
FROM python:3.12-slim as base

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

WORKDIR /app

# Install system dependencies and configure timezone
# Security: apt-get upgrade ensures all system packages are patched
RUN apt-get update && apt-get upgrade -y && apt-get install -y \
    build-essential \
    postgresql-client \
    libpq-dev \
    # WeasyPrint dependencies for PDF generation
    libpango-1.0-0 \
    libpangoft2-1.0-0 \
    libgdk-pixbuf-2.0-0 \
    libffi-dev \
    shared-mime-info \
    libglib2.0-0 \
    libcairo2 \
    libcairo-gobject2 \
    libpangocairo-1.0-0 \
    gir1.2-pango-1.0 \
    # Development tools
    curl \
    vim \
    git \
    tzdata \
    # Health check tools
    procps \
    && rm -rf /var/lib/apt/lists/* \
    # Set timezone to UTC
    && ln -sf /usr/share/zoneinfo/UTC /etc/localtime \
    && echo "UTC" > /etc/timezone \
    && dpkg-reconfigure -f noninteractive tzdata

# Stage 2: Development environment
FROM base as development

# Copy requirements first for better layer caching
COPY requirements/base.txt requirements/local.txt ./

# Install development dependencies
RUN pip install --no-cache-dir -r local.txt

# Copy project files
COPY . .

# Ensure scripts are executable (includes Phase 1 refactored utilities)
RUN chmod +x /app/scripts/*.sh /app/scripts/lib/*.py /app/docker/*.sh 2>/dev/null || true

# Create directories for development
RUN mkdir -p /app/media /app/staticfiles /app/.claude/logs && \
    chmod -R 755 /app

# Development settings
ENV DJANGO_SETTINGS_MODULE=grey_lit_project.settings.local
ENV DEBUG=True

# Expose development ports
EXPOSE 8000 5678

# Development health check (faster interval)
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:${PORT:-8000}/health/', timeout=5)" || exit 1

# Use development entrypoint
COPY docker/dev-entrypoint.sh /dev-entrypoint.sh
RUN chmod +x /dev-entrypoint.sh

ENTRYPOINT ["/dev-entrypoint.sh"]
CMD ["runserver"]

# Stage 3: Staging environment (production-like with enhanced debugging)
FROM base as staging

# Copy requirements for staging (includes some dev tools for debugging)
COPY requirements/base.txt requirements/local.txt ./

# Install staging dependencies (production base + selected dev tools)
RUN pip install --no-cache-dir -r base.txt && \
    # Install selected debugging tools for staging
    pip install --no-cache-dir gunicorn whitenoise psutil

# Copy project for staging
COPY . .

# Ensure scripts are executable (includes Phase 1 refactored utilities)
RUN chmod +x /app/scripts/*.sh /app/scripts/lib/*.py /app/docker/*.sh 2>/dev/null || true

# Staging settings for pre-production validation
ENV DJANGO_SETTINGS_MODULE=grey_lit_project.settings.staging
ENV DEBUG=False

# Create directories and collect static files
RUN mkdir -p /app/media /app/staticfiles /app/logs && \
    chmod -R 755 /app

# Static files will be collected at runtime via staging-startup.sh
# (Cannot run collectstatic during build as Redis/DB services aren't available)
ENV STATIC_URL="/static/"
ENV STATIC_ROOT="/app/staticfiles"

# Create staging user (similar to production but with debugging capabilities)
RUN useradd -m -u 1000 staging_user && \
    chown -R staging_user:staging_user /app && \
    chown -R staging_user:staging_user /app/staticfiles /app/media /app/logs

# Make startup script executable for staging
COPY docker/staging-startup.sh /app/staging-startup.sh
RUN chmod +x /app/staging-startup.sh && chown staging_user:staging_user /app/staging-startup.sh

USER staging_user
EXPOSE 8000

# Staging health check (production-like timing but with more detailed checks)
HEALTHCHECK --interval=45s --timeout=12s --start-period=180s --retries=4 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:${PORT:-8000}/health/', timeout=8)" || exit 1

# Staging entrypoint and default command
ENTRYPOINT ["/app/staging-startup.sh"]
CMD ["production-server"]

# Stage 4: Production environment (for reference)
FROM base as production

# Copy requirements for production
COPY requirements/base.txt requirements/production.txt ./

# Install production dependencies
RUN pip install --no-cache-dir -r production.txt

# Copy project
COPY . .

# Ensure scripts are executable (includes Phase 1 refactored utilities)
RUN chmod +x /app/scripts/*.sh /app/scripts/lib/*.py /app/docker/*.sh 2>/dev/null || true

# Production settings for collectstatic
ENV DJANGO_SETTINGS_MODULE=grey_lit_project.settings.production
ENV SECRET_KEY="dummy-key-for-collectstatic-only"
ENV DATABASE_URL="sqlite:///db.sqlite3"
ENV STATIC_URL="/static/"
ENV STATIC_ROOT="/app/staticfiles"

# Pre-create staticfiles directory and collect static files
RUN mkdir -p /app/staticfiles && \
    python manage.py collectstatic --noinput -v 0

# Create non-root user for production
RUN useradd -m -u 1000 appuser && \
    chown -R appuser:appuser /app && \
    mkdir -p /app/media && \
    chown -R appuser:appuser /app/staticfiles /app/media

# Make startup script executable
COPY docker/startup.sh /app/startup.sh
RUN chmod +x /app/startup.sh && chown appuser:appuser /app/startup.sh

USER appuser
EXPOSE 8000

HEALTHCHECK --interval=60s --timeout=15s --start-period=300s --retries=5 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:${PORT:-8000}/health/', timeout=10)" || exit 1

CMD ["/app/startup.sh"]
