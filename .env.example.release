# Agent Grey - Production Environment Configuration
# Copy this file to .env.local and add your actual values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Serper API Key (Required for search functionality)
# Get your free API key from: https://serper.dev
# Free tier: 2,500 searches per month
SERPER_API_KEY=your-serper-api-key-here

# =============================================================================
# ADMIN ACCOUNT SETUP
# =============================================================================

# Default admin account (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@localhost

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Application Ports (change if needed)
WEB_PORT=8000
DB_PORT=5432
NGINX_PORT=80

# Security (Production)
POSTGRES_PASSWORD=secure_password_change_me
REDIS_PASSWORD=redis_password_change_me

# Domain Configuration (for production deployments)
DOMAIN_NAME=
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Docker Hub Configuration (for custom builds)
DOCKER_HUB_USERNAME=agentgrey
VERSION=latest

# Background Processing
CELERY_CONCURRENCY=2

# Email Notifications (Optional)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# =============================================================================
# SYSTEM SETTINGS (Advanced Users Only)
# =============================================================================

# Performance
DB_MAX_CONNECTIONS=100
REDIS_MAX_CONNECTIONS=50

# Logging
LOG_LEVEL=INFO

# File Upload Limits
MAX_UPLOAD_SIZE=100M
MAX_RESULTS_PER_SEARCH=1000

# =============================================================================
# NOTES
# =============================================================================

# 1. Only SERPER_API_KEY is required to get started
# 2. Change ADMIN_PASSWORD after first login  
# 3. For production, update POSTGRES_PASSWORD and REDIS_PASSWORD
# 4. Visit http://localhost:8000 after installation
# 5. Documentation: https://github.com/your-repo/agent-grey