# Agent Grey - Production Environment Configuration
# Copy this file to .env.production and add your actual production values

# =============================================================================
# PRODUCTION DJANGO SETTINGS
# =============================================================================

DEBUG=False
SECRET_KEY=your-production-secret-key-change-this
DJANGO_SETTINGS_MODULE=grey_lit_project.settings.production

# Production Security
ALLOWED_HOSTS=your-domain.com
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# =============================================================================
# PRODUCTION DATABASE
# =============================================================================

# PostgreSQL Database URL (DigitalOcean Managed Database format)
DATABASE_URL=postgres://username:password@host:port/database

# =============================================================================
# SEARCH API (REQUIRED)
# =============================================================================

# Serper API Key - Get from https://serper.dev/
SERPER_API_KEY=your-production-serper-api-key

# =============================================================================
# REDIS & BACKGROUND PROCESSING
# =============================================================================

# Redis URL (DigitalOcean Managed Redis format)
REDIS_URL=redis://username:password@host:port

# Celery Configuration
CELERY_BROKER_URL=redis://username:password@host:port/0
CELERY_RESULT_BACKEND=redis://username:password@host:port/1

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Production Email Backend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=your-smtp-host.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=Agent Grey <noreply@your-domain.com>

# =============================================================================
# STATIC & MEDIA FILES
# =============================================================================

# Static Files (configure for your CDN/storage)
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# =============================================================================
# SECURITY (PRODUCTION)
# =============================================================================

# CSRF Protection - DigitalOcean App Platform format
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://grey-lit-app-ifa37.ondigitalocean.app

# Environment Identification
ENVIRONMENT=production
DEPLOYMENT_TYPE=digitalocean

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Logging Level
LOG_LEVEL=WARNING
DJANGO_LOG_LEVEL=ERROR

# Sentry for Error Tracking (Recommended for Production)
SENTRY_DSN=https://your-sentry-key@your-sentry-project.ingest.sentry.io/your-project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05
