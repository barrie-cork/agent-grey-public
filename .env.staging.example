# Staging environment example configuration
# Copy to .env.staging.local and customise as needed:
#   cp .env.staging.example .env.staging.local
#
# IMPORTANT: The staging settings (DEBUG=False) enforce that POSTGRES_PASSWORD
# and REDIS_PASSWORD are NOT the insecure defaults. Override them here or via
# environment variables in your CI pipeline.

# Django
SECRET_KEY=staging-secret-key-override-in-production
DEBUG=False

# Database -- must differ from the default "staging_secure_password_456"
POSTGRES_DB=thesis_grey_staging_db
POSTGRES_USER=thesis_grey_staging_user
POSTGRES_PASSWORD=ci-staging-db-password-not-default

# Redis -- must differ from the default "staging_redis_456"
REDIS_PASSWORD=ci-staging-redis-password-not-default

# Search API (optional -- use a test key or leave empty)
SERPER_API_KEY=test-key

# Sentry (optional)
SENTRY_DSN=

# PostHog (disabled in staging by default)
POSTHOG_ENABLED=False
